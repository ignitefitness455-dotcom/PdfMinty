{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RecordedError",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this error instance."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the error occurred."
    },
    "statusCode": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599,
      "description": "The HTTP status code (e.g. 400, 403, 500) associated with the failure."
    },
    "errorClass": {
      "type": "string",
      "enum": ["4XX", "5XX"],
      "description": "Categorization into client-side/operational (4XX) or server-side (5XX)."
    },
    "message": {
      "type": "string",
      "description": "Squeaky-clean scrubbed error message."
    },
    "stack": {
      "type": "string",
      "description": "Sanitized and truncated code stack trace."
    },
    "url": {
      "type": "string",
      "format": "uri-reference",
      "description": "The location/endpoint or path where the exception happened."
    },
    "userAgent": {
      "type": "string",
      "description": "The client browser user-agent string."
    }
  },
  "required": ["id", "timestamp", "statusCode", "errorClass", "message"]
}
