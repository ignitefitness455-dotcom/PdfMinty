{
  "name": "pdfminty",
  "description": "Client-side PDF toolkit",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "optimize-images": "node scripts/optimize-images.js",
    "gen-favicons": "node scripts/gen-favicons.js",
    "build": "node restore_all.js && vite build && node scripts/generate-static-pages.js && node scripts/generate-sitemap.js",
    "lint": "eslint src/ functions/",
    "lint:fix": "eslint src/ functions/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"functions/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"functions/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run build",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@cantoo/pdf-lib": "^2.7.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@google/genai": "^2.6.0",
    "canvas-confetti": "^1.9.3",
    "i18next": "^26.3.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.511.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "i18next-browser-languagedetector": "^7.2.0",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260528.1",
    "@eslint/js": "^9.26.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.6.4",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/ui": "^3.2.3",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "knip": "^5.55.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "puppeteer": "^25.1.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.0.0",
    "terser": "^5.39.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vite": "^6.3.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.3"
  },
  "overrides": {
    "eslint-plugin-import-x": {
      "eslint": "$eslint"
    }
  }
}