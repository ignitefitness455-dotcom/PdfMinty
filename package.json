{
  "name": "pdfminty",
  "version": "1.0.0",
  "description": "Privacy-first, client-side PDF toolkit with server-side AI intelligence.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsx scripts/generate-og-images.ts && tsx scripts/generate-static-pages.ts",
    "pages:dev": "wrangler pages dev dist --compatibility-date=2026-01-01",
    "generate:icons": "tsx scripts/gen-favicons.ts",
    "generate:screenshots": "tsx scripts/generate-screenshots.ts",
    "generate:og-images": "tsx scripts/generate-og-images.ts",
    "generate:images": "tsx scripts/optimize-images.ts",
    "download:font": "tsx scripts/download-font.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ functions/",
    "lint:fix": "eslint src/ functions/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"functions/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"functions/**/*.ts\"",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "prepare": "husky",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build"
  },
  "dependencies": {
    "@cantoo/pdf-lib": "^2.7.1",
    "@google/genai": "^2.9.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "canvas-confetti": "^1.9.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.395.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.3.136",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.23.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.17.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.4.38",
    "prettier": "^3.8.4",
    "sharp": "^0.35.2",
    "tailwindcss": "4.0.0-alpha.14",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.2.11",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  }
}
