{
  "name": "pdfminty",
  "description": "Client-side PDF toolkit",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "optimize-images": "node scripts/optimize-images.js",
    "gen-favicons": "node scripts/gen-favicons.js",
    "build": "node scripts/gen-favicons.js && node scripts/optimize-images.js && tsc && vite build && node scripts/generate-static-pages.js && node scripts/generate-sitemap.js",
    "lint": "eslint src/ functions/",
    "lint:fix": "eslint src/ functions/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"functions/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"functions/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "canvas-confetti": "^1.9.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.446.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260528.1",
    "@eslint/js": "^10.0.1",
    "@google/genai": "^2.6.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.6.4",
    "@types/jszip": "^3.4.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.15.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "terser": "^5.48.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.4.2",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.8"
  }
}
