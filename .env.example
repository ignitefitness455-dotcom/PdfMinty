# URL configuration for canonicals and SEO
VITE_SITE_URL=https://pdfminty.com

# Note: GEMINI_API_KEY will be a Cloudflare secret in production, not a Vite env var.
# For local Pages Functions testing via `wrangler pages dev`, set it in a .dev.vars file:
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-3.5-flash
# RESEND_API_KEY=re_your_api_key
# RESEND_FROM_EMAIL=onboarding@resend.dev
# NOTIFICATION_EMAIL=recipient@example.com
