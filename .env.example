# The base URL for the Cloudflare Pages/Worker backend APIs
# e.g., https://pdfminty-api.yourusername.workers.dev
VITE_API_BASE_URL=
VITE_CLOUDFLARE_API_URL=

# Gemini API Key for local AI document scanning and secure proxy analysis
GEMINI_API_KEY=

# Resend API key for sending contact forms & feedback securely from backend edge endpoints
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NOTIFICATION_EMAIL=

# Custom User-Agent header for proxy requests to external APIs
USER_AGENT=
