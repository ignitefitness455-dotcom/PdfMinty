# Environment variables for PdfMinty

# Required for Gemini AI integration (gemini-proxy.js)
GEMINI_API_KEY=your_gemini_api_key_here

# Required for contact form submissions (contact.js)
RESEND_API_KEY=your_resend_api_key_here

# Required for rate limiting (gemini-proxy.js, contact.js)
# This should be a Cloudflare KV Namespace binding, e.g., 'PDFMINTY_RATE_LIMIT'
RATE_LIMIT_KV=your_cloudflare_kv_binding_name

# Optional: Base URL for the application (e.g., for local development or specific deployments)
# APP_URL="http://localhost:5173"
