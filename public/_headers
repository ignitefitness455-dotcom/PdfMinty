/*
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Clear-Site-Data: "cache", "storage"

/service-worker.js
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Clear-Site-Data: "cache", "storage"
