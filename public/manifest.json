{
  "name": "PDFMinty — Privacy-First PDF Toolkit",
  "short_name": "PDFMinty",
  "description": "Completely offline and secure browser-based PDF suite. Merge, split, compress, protect, and convert PDFs 100% locally in your browser.",
  "id": "/",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "any",
  "lang": "en",
  "dir": "ltr",
  "background_color": "#f8fafc",
  "theme_color": "#059669",
  "categories": ["utilities", "productivity"],
  "icons": [
    {
      "src": "/logo-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/logo-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/logo-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/logo.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "PDFMinty desktop dashboard"
    },
    {
      "src": "/screenshot-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "PDFMinty mobile tool list"
    }
  ],
  "shortcuts": [
    {
      "name": "Merge PDF",
      "short_name": "Merge",
      "description": "Combine multiple PDFs into one",
      "url": "/merge-pdf?source=pwa_shortcut",
      "icons": [{ "src": "/icons/shortcut-merge-96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Compress PDF",
      "short_name": "Compress",
      "description": "Reduce PDF file size",
      "url": "/compress-pdf?source=pwa_shortcut",
      "icons": [{ "src": "/icons/shortcut-compress-96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Split PDF",
      "short_name": "Split",
      "description": "Extract pages or split a PDF",
      "url": "/split-pdf?source=pwa_shortcut",
      "icons": [{ "src": "/icons/shortcut-split-96.png", "sizes": "96x96", "type": "image/png" }]
    }
  ]
}
